generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
  PARENT
  BOARD_MEMBER
}

enum NotificationType {
  POST_PUBLISHED
  POST_CREATED
  COMMENT_ADDED
  REACTION_ADDED
  MESSAGE_RECEIVED
  ATTENDANCE_UPDATED
  ABSENCE_COMMENT_ADDED
  HOMEWORK_COMPLETED
}

enum MessageContextType {
  GENERAL
  HOMEWORK
  LECTURE_COMMENT
  ABSENCE_COMMENT
}

enum MessageKind {
  USER
  SYSTEM
}

enum MessageThreadStatus {
  OPEN
  CLOSED
}

enum BoardMemberRole {
  CHAIRPERSON
  SECRETARY
  ECONOMY
  MEMBER
  ADVISOR
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum CommunityStatus {
  ACTIVE
  INACTIVE
}

enum ChildStatus {
  ACTIVE
  COMPLETED
  DISCONTINUED
  INACTIVE
}

enum LectureStatus {
  DRAFT
  COMPLETED
}

enum EventRecurrence {
  NONE
  WEEKLY
  YEARLY
}

enum EventAudience {
  GENERAL
  CHILDREN
  NIVO
}

model Community {
  id        String   @id @default(uuid())
  name      String   @unique
  description String?
  contactEmail String?
  contactPhone String?
  status    CommunityStatus @default(ACTIVE)
  deactivatedAt DateTime?
  addressId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  address  Address? @relation(fields: [addressId], references: [id])
  users    User[]
  children Child[]
  lectures Lecture[]
  posts    Post[]
  boardMembers CommunityBoardMember[]
  events   Event[]

  @@index([status])
}

model Address {
  id          String   @id @default(uuid())
  streetLine1 String
  streetLine2 String?
  postalCode  String
  city        String
  state       String?
  country     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  communities Community[]
  users       User[]
  boardMembers CommunityBoardMember[]
  children    Child[]

  @@unique([streetLine1, postalCode, city, country])
}

model User {
  id             String   @id @default(uuid())
  firstName      String
  lastName       String
  ssn            String?  @unique
  phoneNumber    String?
  addressId      String?
  email          String   @unique
  passwordHash   String?
  role           Role
  status         UserStatus @default(PENDING)
  invitedById    String?
  communityId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invitedBy      User?    @relation("InvitedBy", fields: [invitedById], references: [id])
  invites        User[]   @relation("InvitedBy")
  community      Community? @relation(fields: [communityId], references: [id])
  address        Address? @relation(fields: [addressId], references: [id])
  parentChildren ParentChild[]
  posts          Post[]
  comments       Comment[]
  reactions      Reaction[]
  lectures       Lecture[]
  sentMessages   Message[] @relation("Sender")
  receivedMessages Message[] @relation("Receiver")
  notifications  Notification[]
  boardMemberships CommunityBoardMember[]
  createdEvents Event[] @relation("EventCreatedBy")
}

model CommunityBoardMember {
  id          String   @id @default(uuid())
  communityId String
  role        BoardMemberRole
  userId      String?
  isActive    Boolean  @default(true)
  mandateStartDate DateTime @default(now())
  mandateEndDate DateTime?
  firstName   String?
  lastName    String?
  email       String?
  phoneNumber String?
  notes       String?
  addressId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  address   Address?  @relation(fields: [addressId], references: [id], onDelete: SetNull)

  @@index([communityId])
  @@index([userId])
  @@index([communityId, isActive])
  @@index([communityId, role, isActive])
}

model Child {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  ssn          String?  @unique
  birthDate    DateTime
  nivo         Int
  status       ChildStatus @default(ACTIVE)
  deactivatedAt DateTime?
  communityId  String
  addressId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  community    Community @relation(fields: [communityId], references: [id])
  address      Address?  @relation(fields: [addressId], references: [id])
  parents      ParentChild[]
  attendance   Attendance[]
  homework     Homework[]
  events       EventChild[]

  @@index([communityId, status])
}

model ParentChild {
  parentId String
  childId  String
  createdAt DateTime @default(now())

  parent User @relation(fields: [parentId], references: [id], onDelete: Cascade)
  child  Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@id([parentId, childId])
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Post {
  id         String   @id @default(uuid())
  title      String
  content    String
  authorId   String
  communityId String
  publishedAt DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  comments Comment[]
  reactions Reaction[]
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Reaction {
  id       String @id @default(uuid())
  kind     String
  postId   String
  userId   String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Message {
  id               String              @id @default(uuid())
  threadId         String
  content          String
  senderId         String
  receiverId       String
  kind             MessageKind         @default(USER)
  contextType      MessageContextType  @default(GENERAL)
  contextChildId   String?
  contextLectureId String?
  contextLabel     String?
  contextPreview   String?
  threadStatus     MessageThreadStatus @default(OPEN)
  createdAt        DateTime            @default(now())

  sender   User @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
}

model Lecture {
  id        String   @id @default(uuid())
  topic     String
  nivo      Int?
  note      String?
  status    LectureStatus @default(DRAFT)
  completedAt DateTime?
  adminId   String
  communityId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admin     User @relation(fields: [adminId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  attendance Attendance[]

  @@index([communityId, status])
}

model Attendance {
  lectureId String
  childId   String
  lessonId  String?
  present   Boolean
  homeworkDone Boolean?
  homeworkTitle String?
  homeworkDescription String?
  comment   String?
  markedAt  DateTime @default(now())

  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  child   Child @relation(fields: [childId], references: [id], onDelete: Cascade)
  lesson  Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@id([lectureId, childId])
  @@index([childId, markedAt])
  @@index([lessonId])
}

model Lesson {
  id        String   @id @default(uuid())
  title     String
  nivo      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  attendance Attendance[]
  homework   Homework[]

  @@unique([title, nivo])
}

model Homework {
  childId   String
  lessonId  String
  title     String
  description String?
  done      Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  child  Child  @relation(fields: [childId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@id([childId, lessonId])
  @@index([childId, lessonId])
  @@index([lessonId])
  @@index([updatedAt])
}

model Notification {
  id        String @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  targetPath String?
  isRead    Boolean @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id                String          @id @default(uuid())
  communityId       String
  createdById       String
  title             String
  description       String?
  startAt           DateTime
  endAt             DateTime
  recurrence        EventRecurrence @default(NONE)
  recurrenceInterval Int            @default(1)
  recurrenceEndsAt  DateTime?
  audience          EventAudience   @default(GENERAL)
  nivo              Int?
  color             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  community Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdBy User       @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  children  EventChild[]

  @@index([communityId, startAt])
  @@index([communityId, audience, startAt])
}

model EventChild {
  eventId   String
  childId   String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@id([eventId, childId])
  @@index([childId])
}
