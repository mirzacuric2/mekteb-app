{
  "name": "mekteb-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "predev": "npm run db:sync:with-seed",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prestart": "npm run db:sync",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed:legacy": "tsx prisma/seed.ts",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:migrate:deploy": "npm run prisma:migrate:deploy",
    "db:seed": "npm run prisma:seed",
    "db:sync": "npm run db:migrate:deploy",
    "db:sync:with-seed": "npm run db:sync && npm run db:seed",
    "db:bootstrap": "npm run prisma:generate && npm run db:sync:with-seed",
    "lint": "echo \"No linter configured yet\""
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.9",
    "@types/nodemailer": "^7.0.11",
    "prisma": "^6.19.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
